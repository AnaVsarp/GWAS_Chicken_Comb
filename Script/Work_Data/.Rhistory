# Day vs Comb weight
ggplot(combined, aes(x = day, y = comb_g, color = rna_sampled)) +
geom_jitter(width = 0.4, alpha = 0.6) +  # Jitter to avoid overlap
labs(title = "Comb Weight by day and RNA samples", x = "day", y = "Weight(gm)") +
theme_minimal()  # Minimalist theme for better visualization
# Comb size vs diet
ggplot(combined, aes(x = comb_g, y = feed, color = breed)) +
geom_jitter(width = 0.4, alpha = 0.6) +  # Jitter to avoid overlap
labs(title = "Comb Weight vs Diet", x = "comb weight", y = "Diet") +
theme_minimal()  # Minimalist theme for better visualization
# Comb size vs housing (cage.pen)
ggplot(combined, aes(x = comb_g, y = cage.pen, color = breed)) +
geom_jitter(width = 0.4, alpha = 0.6) +  # Jitter to avoid overlap
labs(title = "Comb Weight vs Housing", x = "comb weight", y = "Housing") +
theme_minimal()  # Minimalist theme for better visualization
# Comb size vs crossbreeds
ggplot(combined, aes(x = comb_g, y = breed, color = breed)) +
geom_jitter(width = 0.4, alpha = 0.6) +  # Jitter to avoid overlap
labs(title = "Comb Weight vs Breed", x = "comb weight", y = "Breed") +
theme_minimal()  # Minimalist theme for better visualization
# Comb size vs body mass
ggplot(combined, aes(x = comb_g, y = weight, color = breed)) +
geom_jitter(width = 0.4, alpha = 0.6) +  # Jitter to avoid overlap
labs(title = "Comb Weight vs Body Mass", x = "comb weight", y = "Body Mass") +
theme_minimal()  # Minimalist theme for better visualization
# Comb size vs load_N (bone breaking strength)
ggplot(combined, aes(x = comb_g, y = load_N, color = breed)) +
geom_jitter(width = 0.4, alpha = 0.6) +  # Jitter to avoid overlap
labs(title = "Comb Weight vs Bone Breaking Strength", x = "comb weight", y = "Bone Breaking Strength") +
theme_minimal()  # Minimalist theme for better visualization
View(comb_loadN_count)
# Exploratory data analysis
# Feed vs chicken weight
ggplot(combined, aes(x = feed, y = weight, color = breed)) +
geom_jitter(width = 0.4, alpha = 0.6) +  # Jitter to avoid overlap
labs(title = "Comb Weight by Experiment Type and Breed", x = "feed", y = "Weight") +
theme_minimal()  # Minimalist theme for better visualization
