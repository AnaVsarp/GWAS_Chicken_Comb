library(rrBLUP)
library(corrplot)
library(ggplot2)
library(dplyr)
library(hglm)
# Load phenotype and genotype data
pheno <- read.csv("A:/Books/SEM 4/Thesis/GWAS/Script/Work_Data/pheno.csv")
comb_g <- read.csv("A:/Books/SEM 4/Thesis/GWAS/Script/Work_Data/comb_g.csv")
geno <- read.csv("A:/Books/SEM 4/Thesis/GWAS/Script/Work_Data/geno.csv")
library(cowplot)
# Source the functions file
source("A:/Books/SEM 4/Thesis/GWAS/Script/Work_Data/functions.R")
# Load the raw genotype file form PLINK and othe phenotype files
Geno_1 <- read.table("A:/Books/SEM 4/Thesis/GWAS/Script/Work_Data/QC_Files/genotype_qc.raw", header = TRUE)
pheno <- read.csv("A:/Books/SEM 4/Thesis/GWAS/Script/Work_Data/pheno.csv", header = TRUE)
comb_g <- read.csv("A:/Books/SEM 4/Thesis/GWAS/Script/Work_Data/comb_g.csv",header = TRUE)
#Filter the samples whose genotype data is available
pheno_filter <- filter(pheno,animal_id %in% Geno_1$IID)
#Check if the data is oriented in a same order in all the data files
identical(Geno_1$IID, pheno$animal_id)
#order(Geno_1$IID)
#order(pheno$animal_id)
Geno_2<- Geno_1[order(Geno_1$IID),]
pheno_2<- pheno_filter[order(pheno_filter$animal_id),]
identical(Geno_2$IID, pheno_2$animal_id)
#Attach comb data to phenotype and genotype files to remove all the non combmass data samples
comb <- dplyr::select(comb_g, id, comb_mass)
Pheno_file <- inner_join(pheno_2, comb, by = c("animal_id"= "id"))
Geno_join <- inner_join(Geno_2, comb, by = c("IID"= "id"))
Geno_file <- subset(Geno_join, select = -c(comb_mass))
identical(Geno_file$IID, Pheno_file$animal_id)
#Form covariates file
pheno_covariate <- dplyr::select(Pheno_file, feed, cage.pen, breed, weight)
# Prune SNPs
geno_pruned <- prune_snp_matrix(Geno_file)
# Construct GRM
G <- construct_grm(geno_pruned)
# Decomposition of the GRM to create an incidence matrix for the additive genetic effect
Z_grm <- decompose_grm(G, FALSE)
# Add an intercept column (a column of ones) to the covariate matrix
#intercept <- matrix(1, ncol = 1, nrow = nrow(covariate_matrix))
X <-model.matrix(~ 1 + weight + breed + feed + cage.pen, pheno_covariate)
# Number of columns for each random effect; here only one
RandC <- ncol(Z_grm)
# Run GWAS without dominance term
gwasA <- run_gwasA(pheno = Pheno_file$comb_mass, X = X, Z = Z_grm, RandC = RandC, geno_pruned)
# Placeholder for marker positions (replace with actual marker positions if available)
marker_pos <- read.table("A:/Books/SEM 4/Thesis/GWAS/prasanna_comb_sharing/genotypes.map")
colnames(marker_pos) <- c("chromosome", "marker", "distance", "position")
gwasA$marker_id <- sub("_[ATGC]$", replacement = "", gwasA$marker_id)
# Add positions to results
gwasA_pos <- inner_join(gwasA, marker_pos, by = c("marker_id" = "marker"))
View(gwasA_pos)
# Placeholder for QTL positions (replace with actual QTL positions if available)
qtl_pos <- dplyr::select(gwasA_pos,chromosome,position)
View(qtl_pos)
View(qtl_pos)
max(gwasA_pos$estimate)
