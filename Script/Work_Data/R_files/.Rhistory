library(rrBLUP)
library(corrplot)
library(ggplot2)
library(dplyr)
library(hglm)
# Load phenotype and genotype data
pheno <- read.csv("A:/Books/SEM 4/Thesis/GWAS/Script/Work_Data/GWAS_files/Pheno_file.csv")
comb_g <- read.csv("A:/Books/SEM 4/Thesis/GWAS/Script/Work_Data/Input_files/comb_g.csv")
geno <- read.csv("A:/Books/SEM 4/Thesis/GWAS/Script/Work_Data/Input_files/geno.csv")
# Merge phenotype and genotype data
combined <- inner_join(pheno, comb_g, by = c("IID" = "IID"))
#print(feed_weight_count)
ggplot(combined, aes(x = feed, y = weight, color = breed)) +
geom_jitter(width = 0.4, alpha = 1) +  # Jitter to avoid overlap
stat_summary(fun = mean, geom = "point", size = 5, shape = 20, color = "black") +
labs(title = "Feed vs Body mass", x = "feed", y = "Weight (gm)") +
theme_minimal()  # Minimalist theme for better visualization
install.packages("dplyr")
install.packages("ggplot2")
install.packages("dplyr")
install.packages("hglm")
library(rrBLUP)
library(corrplot)
library(ggplot2)
library(dplyr)
library(hglm)
# Load phenotype and genotype data
pheno <- read.csv("A:/Books/SEM 4/Thesis/GWAS/Script/Work_Data/GWAS_files/Pheno_file.csv")
comb_g <- read.csv("A:/Books/SEM 4/Thesis/GWAS/Script/Work_Data/Input_files/comb_g.csv")
geno <- read.csv("A:/Books/SEM 4/Thesis/GWAS/Script/Work_Data/Input_files/geno.csv")
# Merge phenotype and genotype data
combined <- inner_join(pheno, comb_g, by = c("IID" = "IID"))
# Comparing feed groups
t_test_feed <- t.test(weight ~ feed, data = combined)
print(t_test_feed)
# Exploratory data analysis
# Feed vs chicken weight
#feed_weight_count <- combined %>% count(feed, breed)
anova_weight_feed <- aov(weight ~ feed, data = combined)
summary(anova_weight_feed)
#print(feed_weight_count)
ggplot(combined, aes(x = feed, y = weight, color = breed)) +
geom_jitter(width = 0.4, alpha = 1) +  # Jitter to avoid overlap
stat_summary(fun = mean, geom = "point", size = 5, shape = 20, color = "black") +
labs(title = "Feed vs Body mass", x = "feed", y = "Weight (gm)") +
theme_minimal()  # Minimalist theme for better visualization
