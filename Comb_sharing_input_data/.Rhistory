# Define the observed values
observed <- matrix(c(2,42), nrow=2, byrow=TRUE)
Expected <- matrix(c(7,17), nrow=2, byrow=TRUE)
# Perform the chi-square test
chi_sq <- chisq.test(observed,Expected)
# Print the test results
print(chi_sq)
# Perform the chi-square test
chi_sq <- pchisq(observed,Expected, df = 2, lower.tail = FALSE)
# Print the test results
print(chi_sq)
# Perform the chi-square test
chi_sq <- pchisq(observed,Expected, df = 1, lower.tail = FALSE)
# Print the test results
print(chi_sq)
# Define the observed values
observed <- matrix(c(2,42, 7,17), nrow=2, byrow=TRUE)
